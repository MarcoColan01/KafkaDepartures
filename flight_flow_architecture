// Flight Flow architecture
digraph FlightFlow {
	bgcolor=white fontname=Helvetica fontsize=11 rankdir=TB
	node [color=black fillcolor=white fontname=Helvetica fontsize=10 penwidth=1.2 style=filled]
	edge [color="#333333" fontname=Helvetica fontsize=9]
	subgraph cluster_sources {
		color=gray50 fontsize=10 label="EXTERNAL DATA SOURCES" style=dashed
		schiphol_api [label="Schiphol API
(JSON, paginated)" shape=box3d]
		finavia_api [label="Finavia API
(XML + namespace)" shape=box3d]
		avinor_api [label="Avinor XML Feed
(XML, attr-based)" shape=box3d]
	}
	subgraph cluster_pollers {
		color=gray50 fontsize=10 label="HOST-SIDE ADAPTERS (pollers)" style=dashed
		ams_poller [label="AMS Poller" fillcolor="#fff7e6" shape=component]
		hel_poller [label="HEL Poller" fillcolor="#fff7e6" shape=component]
		osl_poller [label="OSL Poller" fillcolor="#fff7e6" shape=component]
	}
	subgraph cluster_docker {
		color=gray30 fillcolor="#f5f5f5" fontsize=10 label="DOCKER NETWORK  (flight-net)" style="rounded,filled"
		api_producer [label="API-Producer
(FastAPI + ResilientProducer)" fillcolor="#e3f2fd" shape=box]
		subgraph cluster_kafka {
			color=orange fillcolor="#fff8e1" fontsize=10 label="KAFKA CLUSTER (KRaft, RF=3, min ISR=2)" style="rounded,filled"
			kafka1 [label="kafka-1" fillcolor="#ffe0b2" shape=cylinder]
			kafka2 [label="kafka-2" fillcolor="#ffe0b2" shape=cylinder]
			kafka3 [label="kafka-3" fillcolor="#ffe0b2" shape=cylinder]
			topics [label="TOPICS
• flight.departures (6 part.)
• flight.statistics (3 part.)
• flight.departed_flights (3 part.)" fillcolor="#fff3cd" shape=folder]
			kafka1 -> topics [style=invis]
			kafka2 -> topics [style=invis]
			kafka3 -> topics [style=invis]
		}
		stats [label="Stats-Aggregator" fillcolor="#e8f5e9" shape=box]
		notifier [label=Notifier fillcolor="#e8f5e9" shape=box]
		dashboard [label="Dashboard
(Flask + SSE)" fillcolor="#e8f5e9" shape=box]
		kafkaui [label="Kafka-UI
(admin)" fillcolor="#fce4ec" shape=box]
	}
	user [label="User browser" fillcolor=white shape=ellipse]
	schiphol_api -> ams_poller [label=HTTPS]
	finavia_api -> hel_poller [label=HTTPS]
	avinor_api -> osl_poller [label=HTTPS]
	ams_poller -> api_producer [label="HTTP POST"]
	hel_poller -> api_producer [label="HTTP POST"]
	osl_poller -> api_producer [label="HTTP POST"]
	api_producer -> topics [label="produce
(mTLS, acks=all)" color="#1565c0"]
	topics -> stats [label="consume telemetry
(static group)" color="#2e7d32"]
	topics -> notifier [label="consume telemetry
(static group)" color="#2e7d32"]
	topics -> dashboard [label="consume all topics
(random group = broadcast)" color="#2e7d32"]
	stats -> topics [label="produce stats" color="#1565c0" style=dashed]
	notifier -> topics [label="produce alerts" color="#1565c0" style=dashed]
	topics -> kafkaui [label="admin
(mTLS)" color="#c2185b" style=dotted]
	dashboard -> user [label="SSE stream
(HTML / JSON)"]
}
